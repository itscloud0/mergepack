+import { describe, expect, it } from "vitest";
+import { total } from "./cart";
+
+describe("total", () => {
+  it("adds cart items", () => {
+    expect(total([2, 3])).toBe(5);
+  });
+
+  it("rejects negative line items", () => {
+    expect(() => total([2, -1])).toThrow("positive");
+  });
+});
